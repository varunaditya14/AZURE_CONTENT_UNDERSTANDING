# Azure Content Understanding resource endpoint (no trailing slash)
AZURE_CU_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# API key for the Azure Content Understanding resource
AZURE_CU_KEY=your_api_key_here

# Analyzer IDs (pre-created in your Azure CU resource)
ANALYZER_ID_DOCUMENT=cu_doc_structured_extractor
ANALYZER_ID_IMAGE=cu_image_content_extractor
ANALYZER_ID_AUDIO=prebuilt-callCenter
ANALYZER_ID_VIDEO=prebuilt-videoSearch

# CORS: comma-separated list of allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:5173
